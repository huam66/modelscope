    "def retrieve(query, top_k=3):\n",
    "    query_vec = model_emb.encode([query], normalize_embeddings=True)\n",
    "    scores, indices = index.search(np.array(query_vec), top_k)\n",
    "    results = [chunks[i] for i in indices[0]]\n",
    "    return results"
